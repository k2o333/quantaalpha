{
  "agents": {
    "codebuddy": {
      "enabled": true,
      "priority": 1,
      "command": ["codebuddy", "-p"],
      "append_args": ["--output-format", "json", "-y"],
      "output_mode": "json",
      "prompt_style": "inline_after_command"
    },
    "qwen": {
      "enabled": true,
      "priority": 2,
      "command": ["qwen", "-p"],
      "append_args": ["--yolo", "--output-format", "json"],
      "output_mode": "json",
      "prompt_style": "inline_after_command"
    },
    "iflow": {
      "enabled": true,
      "priority": 3,
      "command": ["iflow", "-p"],
      "append_args": ["-y"],
      "output_mode": "text",
      "prompt_style": "inline_after_command"
    },
    "kilocode": {
      "enabled": true,
      "priority": 4,
      "command": ["kilo", "run"],
      "append_args": ["--auto", "--format", "json"],
      "output_mode": "json",
      "prompt_style": "append_last"
    },
    "opencode": {
      "enabled": true,
      "priority": 5,
      "command": ["opencode", "run"],
      "append_args": ["--format", "json"],
      "output_mode": "json",
      "prompt_style": "append_last"
    },
    "gemini": {
      "enabled": true,
      "priority": 6,
      "command": ["gemini", "-p"],
      "append_args": ["--approval-mode=yolo", "--output-format", "json"],
      "output_mode": "json",
      "prompt_style": "inline_after_command"
    }
  }
}
